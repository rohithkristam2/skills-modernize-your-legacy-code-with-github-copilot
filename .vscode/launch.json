{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Run Accounting App",
      "program": "${workspaceFolder}/src/accounting/index.js"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Run Jest Tests",
      "program": "${workspaceFolder}/node_modules/jest/bin/jest.js",
      "args": ["src/accounting/index.test.js"],
      "console": "integratedTerminal"
    }
  ]
}
